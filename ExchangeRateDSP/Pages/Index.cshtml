@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboarda";
}

<div class="container mt-4">
    <h2 class="mb-4">Měnové kurzy (Základ: @Model.BaseCurrency)</h2>

    @if (Model.ApiFailed)
    {
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading">Výpadek API!</h4>
            <p>Nepodařilo se získat aktuální data z ExchangeRate API. Zkuste to prosím později.</p>
            <hr>
            <p class="mb-0">Chyba byla zalogována do systému.</p>
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card text-white bg-success mb-3 shadow-sm">
                    <div class="card-header">Nejsilnější měna (nejvyšší hodnota)</div>
                    <div class="card-body">
                        <h4 class="card-title">@Model.StrongestCurrency</h4>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card text-white bg-danger mb-3 shadow-sm">
                    <div class="card-header">Nejslabší měna (nejnižší hodnota)</div>
                    <div class="card-body">
                        <h4 class="card-title">@Model.WeakestCurrency</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="alert alert-info shadow-sm mb-4">
            <i class="bi bi-info-circle-fill"></i>
            <strong>Analýza období:</strong> Celkový aritmetický průměr sledovaných měn za zvolené období je <strong>@Model.AverageRate.ToString("F4")</strong>
        </div>
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white"><strong>Aktuální porovnání kurzů</strong></div>
            <div class="card-body">
                <canvas id="ratesChart" height="100"></canvas>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white"><strong>Vývoj kurzů v čase (Historie)</strong></div>
            <div class="card-body">
                <canvas id="historyChart" height="100"></canvas>
            </div>
        </div>

    }
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const labels = @Html.Raw(Model.ChartLabelsJson);
    const dataValues = @Html.Raw(Model.ChartDataJson);

    if (labels.length > 0) {
        const ctx = document.getElementById('ratesChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Kurz vůči @Model.BaseCurrency',
                    data: dataValues,
                    backgroundColor: 'rgba(54, 162, 235, 0.5)',
                    borderColor: 'rgba(54, 162, 235, 1)',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: { beginAtZero: false }
                }
            }
        });
    }

    const historyLabels = @Html.Raw(Model.HistoryLabelsJson);
    const historyDatasets = @Html.Raw(Model.HistoryDataJson);

    if (historyDatasets.length > 0) {
        const ctxHistory = document.getElementById('historyChart').getContext('2d');
        new Chart(ctxHistory, {
            type: 'line',
            data: {
                labels: historyLabels,
                datasets: historyDatasets
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                    position: 'bottom'
                    }
                },
                scales: {
                    y: { beginAtZero: false }
                }
            }
            });
    }

</script>